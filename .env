# PostgreSQL credentials
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres

# Per-service DB names
AUTH_DB_NAME=authdb
INVENTORY_DB_NAME=inventorydb
TRADE_DB_NAME=tradedb

# Service URLs (used inside containers — service name = hostname)
AUTH_SERVICE_URL=http://auth:8001
INVENTORY_SERVICE_URL=http://inventory:8002

# Ports exposed to your local machine
AUTH_PORT=8001
INVENTORY_PORT=8002
TRADE_PORT=8003

DB_HOST=govtech-project-postgres.ctg00icwynan.ap-southeast-1.rds.amazonaws.com